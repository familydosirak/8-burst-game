rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /weeklyRankings/{weekId}/scores/{userId} {
      allow read: if request.auth != null;

      allow create: if isValidScore(userId, weekId);

      allow update: if isValidScore(userId, weekId)
        && request.resource.data.score >= resource.data.score;

      allow delete: if false;
    }

    function isValidScore(userId, weekId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'uid',
          'nickname',
          'score',
          'bestCombo',
          'turn',
          'weekId',
          'updatedAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.weekId == weekId
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 1
        && request.resource.data.nickname.size() <= 12
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000000000
        && request.resource.data.bestCombo is int
        && request.resource.data.bestCombo >= 0
        && request.resource.data.bestCombo <= 1000000
        && request.resource.data.turn is int
        && request.resource.data.turn >= 0
        && request.resource.data.turn <= 1000000;
    }
  }
}
